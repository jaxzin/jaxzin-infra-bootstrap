# Provisioned by the gitea_backup role (Ansible template, no_log, root 0600).
# Sourced by the best-effort on-restart / on-deploy self-heal that re-asserts
# Gitea's authentik OAuth2 source (the thing that governs site-admin +
# fallen-leaf ownership). Holds a SCOPED, short-lived OpenBao token — not an
# admin token. If OpenBao is unreachable (e.g. DR, Gitea boots first) the
# self-heal logs and skips; this file being stale is non-fatal by design.
BAO_ADDR={{ gitea_oidc_reconcile_bao_addr }}
BAO_TOKEN={{ gitea_oidc_reconcile_bao_token }}
TS_TAILNET={{ tailscale_tailnet }}
