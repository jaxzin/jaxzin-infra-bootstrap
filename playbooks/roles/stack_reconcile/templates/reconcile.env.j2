# stack_reconcile secret env-file — 0600 root, templated with no_log: true.
# The Discord webhook is a credential, so it lives ONLY here. It is sourced by
# the cron wrapper and bind-mounted read-only into the watchdog container; it
# is NEVER passed on the cron line, in the container env:, or into deploy logs.
# `export` so a process that sources this file (the watchdog loop, which then
# execs the reconcile script as a CHILD) actually inherits the value — without
# export the child sees nothing and alert() silently no-ops.
export RECONCILE_DISCORD_WEBHOOK='{{ stack_reconcile_discord_webhook }}'
