; ; Gitea app.ini configuration, managed by Ansible
WORK_PATH = /var/lib/gitea

[server]
PROTOCOL = {{ gitea_protocol | default('https') }}
DOMAIN = {{ gitea_domain }}
ROOT_URL = {{ gitea_root_url | default('https://' + gitea_domain + ':' + gitea_port + '/') }}
{% if gitea_protocol | default('https') == 'https' %}
CERT_FILE = /etc/letsencrypt/live/{{ certbot_domain | default(gitea_domain) }}/fullchain.pem
KEY_FILE = /etc/letsencrypt/live/{{ certbot_domain | default(gitea_domain) }}/privkey.pem
{% endif %}
SSH_PORT = {{ gitea_ssh_port }}
SSH_DOMAIN = {{ gitea_ssh_domain | default(gitea_domain) }}
{% if tailscale_enabled | default(false) | bool %}
START_SSH_SERVER = true
SSH_LISTEN_PORT = {{ gitea_ssh_listen_port }}
{% endif %}

[database]
DB_TYPE = mysql
HOST = gitea-db:3306
NAME = {{ gitea_db_name }}
USER = {{ gitea_db_user }}
PASSWD = {{ gitea_db_password }}

[security]
INSTALL_LOCK = true
INTERNAL_TOKEN_URI = file:/etc/gitea/secrets/internal_token

[actions]
ENABLED = true

[oauth2]
JWT_SECRET = {{ gitea_jwt_secret }}
