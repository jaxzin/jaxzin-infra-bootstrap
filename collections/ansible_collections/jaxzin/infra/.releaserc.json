{
  "branches": ["main"],
  "tagFormat": "${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md",
        "changelogTitle": "# Changelog"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "./scripts/release-prepare.sh ${nextRelease.version}",
        "publishCmd": "ansible-galaxy collection publish jaxzin-infra-${nextRelease.version}.tar.gz --api-key \"$GALAXY_API_KEY\""
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["galaxy.yml", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "jaxzin-infra-*.tar.gz",
            "label": "Ansible collection tarball"
          }
        ]
      }
    ]
  ]
}
